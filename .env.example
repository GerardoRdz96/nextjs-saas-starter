# ============================================================
# Next.js SaaS Starter — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# ---- Supabase -----------------------------------------------
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Stripe -------------------------------------------------
# Find these in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook secret: Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- App ----------------------------------------------------
# Your Railway app URL (set automatically by Railway on deploy)
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
